# Copy this file to .env and fill in your values.
# Never commit .env to source control.

WIFI_SSID=YourNetworkName
WIFI_PASSWORD=YourPassword

# Optional: set to true to generate a compact set of 6 QR codes (default: false)
# COMPACT=true

# Optional: change the output file path (default: wifi-qr.pdf)
# OUTPUT=wifi-qr.pdf
